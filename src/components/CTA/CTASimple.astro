---
// Call To Action Component for Veritas GRC
---

<section class="veritas-cta-section" style="max-width: 1000px; margin: 6rem auto; padding: 0 1.5rem; font-family: system-ui, -apple-system, sans-serif; box-sizing: border-box;">
  <div class="veritas-cta-card">
    <div class="veritas-cta-content">
      <h2 class="veritas-cta-title">Ready to Elevate Your Clinical Research Governance?</h2>
      <p class="veritas-cta-description">
        Partner with Veritas GRC to proactively mitigate regulatory risks, protect clinical trial participant data, and establish flawless data integrity frameworks.
      </p>
    </div>
    <div class="veritas-cta-actions">
      <a href="/contact" class="v-btn-p">Consult Our Advisors</a>
      <a href="/services" class="v-btn-s">Explore Solutions</a>
    </div>
  </div>
</section>

<style>
/* High-specificity class overrides to isolate against third-party global stylesheets */
.veritas-cta-card {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #1a3e6f 100%) !important;
  padding: 3.5rem 3rem !important;
  border-radius: 1.25rem !important;
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 3rem !important;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
  position: relative !important;
  overflow: hidden !important;
  box-sizing: border-box !important;
  width: 100% !important;
}

.veritas-cta-card::after {
  content: "";
  position: absolute;
  bottom: -50px;
  right: -50px;
  width: 250px;
  height: 250px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(44, 90, 158, 0.25) 0%, transparent 70%);
  filter: blur(20px);
  pointer-events: none;
}

.veritas-cta-content {
  flex: 1 1 60% !important;
  z-index: 1 !important;
}

.veritas-cta-title {
  color: #ffffff !important;
  font-size: 2rem !important;
  font-weight: 700 !important;
  line-height: 1.3 !important;
  margin: 0 0 1rem 0 !important;
  letter-spacing: -0.01em !important;
}

.veritas-cta-description {
  color: #94a3b8 !important;
  font-size: 1.1rem !important;
  line-height: 1.6 !important;
  margin: 0 !important;
}

.veritas-cta-actions {
  flex: 0 0 auto !important;
  display: flex !important;
  gap: 1rem !important;
  z-index: 1 !important;
}

/* Rebuilt and reinforced interactive layout links */
.v-btn-p {
  background-color: #ffffff !important;
  color: #0f172a !important;
  padding: 0.85rem 1.75rem !important;
  border-radius: 0.5rem !important;
  font-weight: 600 !important;
  text-decoration: none !important;
  font-size: 0.95rem !important;
  transition: background-color 0.2s ease, transform 0.1s ease !important;
  white-space: nowrap !important;
  display: inline-block !important;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
  border: none !important;
  box-sizing: border-box !important;
}

.v-btn-p:hover {
  background-color: #f1f5f9 !important;
  transform: translateY(-1px) !important;
}

.v-btn-s {
  background-color: rgba(255, 255, 255, 0.1) !important;
  color: #ffffff !important;
  padding: 0.85rem 1.75rem !important;
  border-radius: 0.5rem !important;
  font-weight: 600 !important;
  text-decoration: none !important;
  font-size: 0.95rem !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
  transition: background-color 0.2s ease, border-color 0.2s ease !important;
  white-space: nowrap !important;
  display: inline-block !important;
  box-sizing: border-box !important;
}

.v-btn-s:hover {
  background-color: rgba(255, 255, 255, 0.15) !important;
  border-color: rgba(255, 255, 255, 0.4) !important;
}

/* Responsive breakout layout */
@media (max-width: 868px) {
  .veritas-cta-card {
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 2rem !important;
    padding: 2.5rem 2rem !important;
  }
  
  .veritas-cta-title {
    font-size: 1.75rem !important;
  }

  .veritas-cta-actions {
    width: 100% !important;
    flex-direction: column !important;
  }

  .v-btn-p, .v-btn-s {
    text-align: center !important;
    width: 100% !important;
  }
}
</style>
