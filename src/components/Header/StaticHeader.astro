---
// src/components/Header/StaticHeader.astro
import DarkModeToggle from "@components/DarkModeToggle/DarkModeToggle.astro";
---

<header id="cs-navigation">
  <div class="cs-container">
    <!-- Brand -->
    <a href="/" class="cs-logo">
      <div class="cs-brand">
        <div class="cs-brand-name">Veritas GRC</div>
        <div class="cs-tagline">Advancing Integrity in Clinical Research</div>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="cs-nav">
      <ul class="cs-nav-list">
        <li><a href="/">Home</a></li>
        <li><a href="/research">Research</a></li>
        <li><a href="/guides">Guides</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>

    <div class="cs-right-group">
      <DarkModeToggle />
      <button class="cs-toggle" aria-label="Menu">
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="cs-mobile-menu" hidden>
    <ul class="cs-mobile-nav-list">
      <li><a href="/">Home</a></li>
      <li><a href="/research">Research</a></li>
      <li><a href="/guides">Guides</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </div>
</header>

<style>
  .cs-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .cs-logo {
    text-decoration: none;
  }
  .cs-brand-name {
    font-size: 1.5rem;
    font-weight: bold;
    color: #1e3a5f;
  }
  .cs-tagline {
    font-size: 0.75rem;
    color: #4a6a8b;
  }
  .cs-nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cs-nav-list a {
    text-decoration: none;
    color: #1e3a5f;
  }
  .cs-right-group {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .cs-toggle {
    display: none;
    background: none;
    border: 1px solid #ccc;
    padding: 0.5rem;
    cursor: pointer;
  }
  @media (max-width: 700px) {
    .cs-nav {
      display: none;
    }
    .cs-toggle {
      display: block;
    }
  }
  .cs-mobile-menu {
    border-top: 1px solid #eee;
    padding: 1rem;
  }
  .cs-mobile-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cs-mobile-nav-list li {
    margin-bottom: 0.75rem;
  }
</style>

<script>
  const toggle = document.querySelector('.cs-toggle');
  const mobileMenu = document.querySelector('.cs-mobile-menu');
  if (toggle && mobileMenu) {
    toggle.addEventListener('click', () => {
      mobileMenu.hidden = !mobileMenu.hidden;
    });
  }
</script>
