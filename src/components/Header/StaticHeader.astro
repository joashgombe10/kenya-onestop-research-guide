---
// src/components/Header/StaticHeader.astro
import { Icon } from "astro-icon/components";
import DarkModeToggle from "@components/DarkModeToggle/DarkModeToggle.astro";
---

<header id="cs-navigation">
  <div class="cs-container">
    <!-- Logo / Brand -->
    <a href="/" class="cs-logo" aria-label="Veritas GRC home page">
      <div class="cs-brand">
        <span class="cs-brand-name">Veritas GRC</span>
        <span class="cs-tagline">Advancing Integrity in Clinical Research</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="cs-nav" aria-label="Primary">
      <ul class="cs-nav-list">
        <li><a href="/research" class="cs-nav-link">Research</a></li>
        <li><a href="/guides" class="cs-nav-link">Guides</a></li>
        <li><a href="/about" class="cs-nav-link">About</a></li>
      </ul>
    </nav>

    <!-- Right side items -->
    <div class="cs-right-group">
      <DarkModeToggle />
      <!-- Mobile menu toggle button -->
      <button class="cs-toggle" aria-label="menu" aria-expanded="false">
        <span class="cs-toggle-icon"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div class="cs-mobile-menu" hidden>
    <nav aria-label="Mobile">
      <ul class="cs-mobile-nav-list">
        <li><a href="/research">Research</a></li>
        <li><a href="/guides">Guides</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* Reset / base */
  .cs-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Brand styling */
  .cs-logo {
    text-decoration: none;
  }
  .cs-brand {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .cs-brand-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-color, #1a2c3e);
    letter-spacing: -0.02em;
  }
  .cs-tagline {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted, #4a627a);
    letter-spacing: 0.02em;
  }
  /* Dark mode variables (example) */
  :root {
    --text-color: #1a2c3e;
    --text-muted: #4a627a;
  }
  :root.dark {
    --text-color: #f0f4f8;
    --text-muted: #b0c4de;
  }

  /* Desktop navigation */
  .cs-nav-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cs-nav-link {
    text-decoration: none;
    font-weight: 500;
    color: var(--text-color, #1a2c3e);
    transition: color 0.2s;
  }
  .cs-nav-link:hover {
    color: #2c7da0;
  }

  /* Right group */
  .cs-right-group {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Mobile toggle button */
  .cs-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .cs-toggle-icon {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    position: relative;
  }
  .cs-toggle-icon::before,
  .cs-toggle-icon::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background: currentColor;
    left: 0;
  }
  .cs-toggle-icon::before {
    top: -8px;
  }
  .cs-toggle-icon::after {
    bottom: -8px;
  }

  /* Mobile menu */
  .cs-mobile-menu {
    background: var(--bg-mobile, #ffffff);
    border-top: 1px solid #e2e8f0;
    padding: 1rem;
  }
  .cs-mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cs-mobile-nav-list a {
    text-decoration: none;
    color: var(--text-color, #1a2c3e);
    font-weight: 500;
    display: block;
    padding: 0.5rem 0;
  }

  /* Responsive breakpoint */
  @media (max-width: 768px) {
    .cs-nav {
      display: none;
    }
    .cs-toggle {
      display: block;
    }
    .cs-brand-name {
      font-size: 1.25rem;
    }
    .cs-tagline {
      font-size: 0.65rem;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const toggleBtn = document.querySelector('.cs-toggle');
  const mobileMenu = document.querySelector('.cs-mobile-menu');
  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', !expanded);
      mobileMenu.hidden = !mobileMenu.hidden;
    });
  }
</script>
