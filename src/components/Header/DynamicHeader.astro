---
import DarkModeToggle from "@components/DarkModeToggle/DarkModeToggle.astro";
---

<header class="dynamic-header">
  <div class="header-container">
    <a href="/" class="brand-link">
      <div class="brand">
        <span class="brand-name">Veritas GRC</span>
        <span class="tagline">Advancing Integrity in Clinical Research</span>
      </div>
    </a>

    <nav class="desktop-nav">
      <ul class="nav-list">
        <li><a href="/" class="nav-link">Home</a></li>
        <li class="dropdown">
          <details>
            <summary>Services</summary>
            <ul>
              <li><a href="/services/ethics">Ethics</a></li>
              <li><a href="/services/academy">Academy</a></li>
              <li><a href="/services/digital">Digital</a></li>
              <li><a href="/services/audits">Audits</a></li>
              <li><a href="/services/analytics">Analytics</a></li>
            </ul>
          </details>
        </li>
        <li><a href="/about" class="nav-link">About</a></li>
        <li><a href="/contact" class="nav-link">Contact</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <DarkModeToggle />
      <button class="mobile-toggle" aria-label="Menu">☰</button>
    </div>
  </div>

  <div class="mobile-nav" hidden>
    <ul>
      <li><a href="/">Home</a></li>
      <li><details><summary>Services</summary><ul><li><a href="/services/ethics">Ethics</a></li><li><a href="/services/academy">Academy</a></li><li><a href="/services/digital">Digital</a></li><li><a href="/services/audits">Audits</a></li><li><a href="/services/analytics">Analytics</a></li></ul></details></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </div>
</header>

<style>
  /* Basic styles (keep your existing dark mode variables) */
  .dynamic-header { background: var(--header-bg, #fff); border-bottom: 1px solid var(--border-color, #e2e8f0); }
  .header-container { display: flex; justify-content: space-between; align-items: center; max-width: 1280px; margin: 0 auto; padding: 0.75rem 1.5rem; }
  .brand-link { text-decoration: none; }
  .brand-name { font-size: 1.5rem; font-weight: 700; color: var(--brand-color, #1e3a5f); }
  .tagline { font-size: 0.7rem; color: var(--tagline-color, #4a6a8b); }
  .nav-list { display: flex; gap: 1.5rem; list-style: none; margin: 0; padding: 0; align-items: center; }
  .nav-link { text-decoration: none; font-weight: 500; color: var(--nav-link, #1e293b); }
  details { position: relative; }
  summary { font-weight: 500; color: var(--nav-link, #1e293b); cursor: pointer; list-style: none; }
  summary::after { content: "▼"; font-size: 0.7rem; margin-left: 0.25rem; }
  details ul { position: absolute; top: 100%; left: 0; background: var(--dropdown-bg, #fff); border: 1px solid var(--border-color, #e2e8f0); border-radius: 0.5rem; padding: 0.5rem 0; min-width: 180px; list-style: none; margin: 0.5rem 0 0 0; }
  details ul li a { display: block; padding: 0.5rem 1rem; text-decoration: none; color: var(--nav-link, #1e293b); }
  .mobile-toggle { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; }
  .mobile-nav { background: var(--mobile-bg, #fff); border-top: 1px solid var(--border-color, #e2e8f0); padding: 1rem; }
  .mobile-nav ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .mobile-nav details ul { position: static; margin-left: 1rem; }
  @media (max-width: 768px) { .desktop-nav { display: none; } .mobile-toggle { display: block; } }
  /* Add dark mode variables as you already have */
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const mobileNav = document.querySelector('.mobile-nav');
  if (toggle && mobileNav) toggle.addEventListener('click', () => mobileNav.hidden = !mobileNav.hidden);
</script>
