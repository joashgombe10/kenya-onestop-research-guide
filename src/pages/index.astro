---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kenya Research Guidance Hub" description="Clear, practical guidance for ethical research and regulatory compliance in Kenya">
  <main class="homepage">
    <section class="hero">
      <h1>Kenya One‑Stop Research Guide</h1>
      <p class="tagline">Your plain‑English pathway from research idea to NACOSTI permit.</p>
      <a href="/blog" class="cta-button">Start Here →</a>
    </section>

    <section class="features">
      <div class="feature">
        <h2>Step‑by‑Step Guidance</h2>
        <p>IRB approval → County clearance → NACOSTI. No confusion, no missed steps.</p>
      </div>
      <div class="feature">
        <h2>Regulatory Bodies</h2>
        <p>Clear explanations of NACOSTI, KNH/UoN ERC, Ministry of Health, and more.</p>
      </div>
      <div class="feature">
        <h2>Downloadable Templates</h2>
        <p>Informed consent forms, checklists, and MTA templates in English and Swahili.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .homepage {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  .hero {
    text-align: center;
    padding: 3rem 1rem;
    background: #f0f7ff;
    border-radius: 1rem;
    margin-bottom: 3rem;
  }
  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #1a3e6f;
  }
  .tagline {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    color: #2c5a9e;
  }
  .cta-button {
    background: #1a3e6f;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: bold;
  }
  .cta-button:hover {
    background: #0f2c4f;
  }
  .features {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .feature {
    flex: 1;
    min-width: 200px;
    background: white;
    padding: 1.5rem;
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    border: 1px solid #e0e7f0;
  }
  .feature h2 {
    font-size: 1.5rem;
    margin-top: 0;
    color: #1a3e6f;
  }
</style>
