---
// src/components/Header/DynamicHeader.astro
import DarkModeToggle from "@components/DarkModeToggle/DarkModeToggle.astro";
---

<header class="dynamic-header">
  <div class="header-container">
    <!-- Logo / Brand -->
    <a href="/" class="brand-link" aria-label="Veritas GRC home">
      <div class="brand">
        <span class="brand-name">Veritas GRC</span>
        <span class="tagline">Advancing Integrity in Clinical Research</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Main">
      <ul class="nav-list">
        <li><a href="/" class="nav-link">Home</a></li>
        <li><a href="/research" class="nav-link">Research</a></li>
        <li><a href="/guides" class="nav-link">Guides</a></li>
        <li><a href="/about" class="nav-link">About</a></li>
      </ul>
    </nav>

    <!-- Right side: dark mode toggle + mobile menu button -->
    <div class="header-actions">
      <DarkModeToggle />
      <button class="mobile-toggle" aria-label="Menu" aria-expanded="false">
        <span class="toggle-icon"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation (hidden by default) -->
  <div class="mobile-nav" hidden>
    <ul class="mobile-nav-list">
      <li><a href="/" class="mobile-nav-link">Home</a></li>
      <li><a href="/research" class="mobile-nav-link">Research</a></li>
      <li><a href="/guides" class="mobile-nav-link">Guides</a></li>
      <li><a href="/about" class="mobile-nav-link">About</a></li>
    </ul>
  </div>
</header>

<style>
  .dynamic-header {
    background: var(--header-bg, #ffffff);
    border-bottom: 1px solid var(--border-color, #e2e8f0);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .brand-link {
    text-decoration: none;
  }
  .brand {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .brand-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--brand-color, #1e3a5f);
    letter-spacing: -0.02em;
  }
  .tagline {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--tagline-color, #4a6a8b);
    letter-spacing: 0.3px;
  }

  :root {
    --header-bg: #ffffff;
    --border-color: #e2e8f0;
    --brand-color: #1e3a5f;
    --tagline-color: #4a6a8b;
    --nav-link: #1e293b;
    --nav-link-hover: #2c7da0;
    --mobile-bg: #ffffff;
  }
  .dark-mode {
    --header-bg: #1e293b;
    --border-color: #334155;
    --brand-color: #f0f4f8;
    --tagline-color: #b0c4de;
    --nav-link: #cbd5e1;
    --nav-link-hover: #81e6d9;
    --mobile-bg: #1e293b;
  }

  .desktop-nav {
    display: flex;
  }
  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    text-decoration: none;
    font-weight: 500;
    color: var(--nav-link, #1e293b);
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: var(--nav-link-hover, #2c7da0);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--brand-color, #1e3a5f);
  }
  .toggle-icon {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    position: relative;
  }
  .toggle-icon::before,
  .toggle-icon::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background: currentColor;
    left: 0;
  }
  .toggle-icon::before {
    top: -8px;
  }
  .toggle-icon::after {
    bottom: -8px;
  }

  .mobile-nav {
    background: var(--mobile-bg, #ffffff);
    border-top: 1px solid var(--border-color, #e2e8f0);
    padding: 1rem 1.5rem;
  }
  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mobile-nav-link {
    text-decoration: none;
    color: var(--nav-link, #1e293b);
    font-weight: 500;
    display: block;
    padding: 0.5rem 0;
  }
  .mobile-nav-link:hover {
    color: var(--nav-link-hover, #2c7da0);
  }

  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }
    .mobile-toggle {
      display: block;
    }
    .brand-name {
      font-size: 1.25rem;
    }
    .tagline {
      font-size: 0.6rem;
    }
  }
</style>

<script>
  const toggleBtn = document.querySelector('.mobile-toggle');
  const mobileNav = document.querySelector('.mobile-nav');
  if (toggleBtn && mobileNav) {
    toggleBtn.addEventListener('click', () => {
      const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', !expanded);
      mobileNav.hidden = !mobileNav.hidden;
    });
  }
</script>
