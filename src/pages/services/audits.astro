---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Audits | Veritas GRC" description="Comprehensive compliance evaluations, quality assurance reviews, and system monitoring frameworks.">
  <main class="service-page">
    <h1>Audits</h1>
    <p>Comprehensive compliance evaluations, quality assurance reviews, and system monitoring frameworks to keep your clinical trials audit-ready and aligned with global regulatory demands.</p>
    <h2>Our Auditing Services</h2>
    <ul>
      <li>Trial site compliance audits and quality assurance assessments</li>
      <li>Good Clinical Practice (GCP) and regulatory gap analysis</li>
      <li>Mock regulatory inspection preparation and training</li>
      <li>Vendor and data management system validation reviews</li>
    </ul>
    <a href="/contact" class="cta">Schedule an Audit →</a>
  </main>
</BaseLayout>

<style>
  .service-page { max-width: 800px; margin: 2rem auto; padding: 2rem; }
  h1 { color: #1a3e6f; }
  .cta { display: inline-block; margin-top: 2rem; background: #1a3e6f; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; }
  .cta:hover { background: #0f2c4f; }
</style>
