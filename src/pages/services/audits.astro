---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Veritas GRC Audits | Independent Audits & Inspections" description="Independent audits, mock inspections, and vendor compliance assessments for clinical research.">
  <main class="service-page">
    <h1>Veritas GRC Audits</h1>
    <p>Ensure your clinical trials and systems are inspection-ready with our independent audit services.</p>
    <h2>Audit Services</h2>
    <ul>
      <li>Independent GCP/GMP audits</li>
      <li>Mock regulatory inspections (FDA, EMA, MHRA, NACOSTI)</li>
      <li>Vendor and CRO compliance assessments</li>
      <li>Audit readiness training</li>
    </ul>
    <a href="/contact" class="cta">Schedule an audit →</a>
  </main>
</BaseLayout>

<style>
  .service-page { max-width: 800px; margin: 2rem auto; padding: 2rem; }
  h1 { color: #1a3e6f; }
  .cta { display: inline-block; margin-top: 2rem; background: #1a3e6f; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; }
</style>
