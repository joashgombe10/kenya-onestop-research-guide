---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Academy | Veritas GRC" description="Professional training, specialized workshops, and comprehensive educational resources designed to elevate clinical research standards.">
  <main class="service-page">
    <h1>Academy</h1>
    <p>Professional training, specialized workshops, and comprehensive educational resources designed to elevate clinical research standards and regulatory compliance.</p>
    <h2>Our Educational Programs</h2>
    <ul>
      <li>Good Clinical Practice (GCP) certification courses</li>
      <li>Research ethics and IRB submission workshops</li>
      <li>Data management and statistical analysis seminars</li>
      <li>Customized institutional compliance training programs</li>
    </ul>
    <a href="/contact" class="cta">Explore Academy Programs →</a>
  </main>
</BaseLayout>

<style>
  .service-page { max-width: 800px; margin: 2rem auto; padding: 2rem; }
  h1 { color: #1a3e6f; }
  .cta { display: inline-block; margin-top: 2rem; background: #1a3e6f; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; }
  .cta:hover { background: #0f2c4f; }
</style>
