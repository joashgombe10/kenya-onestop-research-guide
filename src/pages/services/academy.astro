---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Veritas GRC Academy | Training & Certifications" description="Training programs, GCP certifications, and workshops on regulatory compliance and research integrity.">
  <main class="service-page">
    <h1>Veritas GRC Academy</h1>
    <p>Empower your team with our accredited training programs designed to foster excellence in clinical research.</p>
    <h2>Offerings</h2>
    <ul>
      <li>Good Clinical Practice (GCP) certification</li>
      <li>Regulatory compliance workshops</li>
      <li>Research integrity seminars</li>
      <li>Custom on-site training for organizations</li>
    </ul>
    <a href="/contact" class="cta">Request training info →</a>
  </main>
</BaseLayout>

<style>
  .service-page { max-width: 800px; margin: 2rem auto; padding: 2rem; }
  h1 { color: #1a3e6f; }
  .cta { display: inline-block; margin-top: 2rem; background: #1a3e6f; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; }
</style>
