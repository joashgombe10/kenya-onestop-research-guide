---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Veritas GRC Analytics | Risk-Based Monitoring & Analytics" description="Risk-based monitoring, data analytics, and performance metrics for clinical operations.">
  <main class="service-page">
    <h1>Veritas GRC Analytics</h1>
    <p>Turn clinical data into actionable insights with our advanced analytics and risk-based monitoring solutions.</p>
    <h2>Analytics Offerings</h2>
    <ul>
      <li>Risk-based monitoring (RBM) implementation</li>
      <li>Clinical trial data analytics dashboards</li>
      <li>Key performance indicators (KPIs) for clinical operations</li>
      <li>Predictive analytics for site selection and patient recruitment</li>
    </ul>
    <a href="/contact" class="cta">Talk to our analytics team →</a>
  </main>
</BaseLayout>

<style>
  .service-page { max-width: 800px; margin: 2rem auto; padding: 2rem; }
  h1 { color: #1a3e6f; }
  .cta { display: inline-block; margin-top: 2rem; background: #1a3e6f; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; }
</style>
