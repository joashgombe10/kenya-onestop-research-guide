---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Analytics | Veritas GRC" description="Advanced data processing, specialized statistical insights, and structured research analysis to ensure the integrity of findings.">
  <main class="service-page">
    <h1>Analytics</h1>
    <p>Advanced data processing, specialized statistical insights, and structured research analysis to ensure the integrity, precision, and validity of clinical findings.</p>
    <h2>Our Data & Analysis Services</h2>
    <ul>
      <li>Biostatistical consultation and protocol development</li>
      <li>Data management plan setup and validation modeling</li>
      <li>Interim analysis generation and statistical reporting</li>
      <li>Advanced research methodology and data visualization systems</li>
    </ul>
    <a href="/contact" class="cta">Request Analytics Support →</a>
  </main>
</BaseLayout>

<style>
  .service-page { max-width: 800px; margin: 2rem auto; padding: 2rem; }
  h1 { color: #1a3e6f; }
  .cta { display: inline-block; margin-top: 2rem; background: #1a3e6f; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; }
  .cta:hover { background: #0f2c4f; }
</style>
