---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Services | Veritas GRC">
  <main class="services-container" style="max-width: 1200px; margin: 0 auto; padding: 2rem 1rem;">
    <h1 style="font-size: 2.5rem; margin-bottom: 2rem; font-weight: bold;">Our Service Divisions</h1>

    <div class="services-list" style="display: flex; flex-direction: column; gap: 2rem;">
      
      <section class="service-item" style="padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--text-color, #111);">Veritas GRC Ethics</h2>
        <p style="margin-bottom: 1rem; color: #555;">Expert research ethics, IRB submissions, and regulatory oversight.</p>
        <a href="/services/ethics" style="color: #0066cc; font-weight: 500; text-decoration: none;">Explore Ethics Services →</a>
      </section>

      <section class="service-item" style="padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--text-color, #111);">Academy</h2>
        <p style="margin-bottom: 1rem; color: #555;">Professional training, workshops, and educational resources.</p>
        <a href="/services/academy" style="color: #0066cc; font-weight: 500; text-decoration: none;">Explore Academy →</a>
      </section>

      <section class="service-item" style="padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--text-color, #111);">Analytics</h2>
        <p style="margin-bottom: 1rem; color: #555;">Data processing, statistical insights, and research analysis.</p>
        <a href="/services/analytics" style="color: #0066cc; font-weight: 500; text-decoration: none;">Explore Analytics →</a>
      </section>

      <section class="service-item" style="padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--text-color, #111);">Audits</h2>
        <p style="margin-bottom: 1rem; color: #555;">Compliance evaluation, quality assurance, and system monitoring.</p>
        <a href="/services/audits" style="color: #0066cc; font-weight: 500; text-decoration: none;">Explore Audits →</a>
      </section>

      <section class="service-item" style="padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--text-color, #111);">Digital</h2>
        <p style="margin-bottom: 1rem; color: #555;">Digital transformation, automated workflows, and research infrastructure.</p>
        <a href="/services/digital" style="color: #0066cc; font-weight: 500; text-decoration: none;">Explore Digital Services →</a>
      </section>

    </div>
  </main>
</BaseLayout>
